{
  "name": "@agentex/agent",
  "version": "0.0.19",
  "description": "Programmatic execution of AI coding agents (Claude Code, Codex, OpenClaw)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dynamismlabs/agentex.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/dynamismlabs/agentex/tree/main/packages/agent#readme",
  "bugs": {
    "url": "https://github.com/dynamismlabs/agentex/issues"
  },
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:mock": "tsx scripts/smoke.ts --mock",
    "smoke:concurrent": "tsx scripts/concurrent-smoke.ts",
    "list-models": "tsx scripts/list-models.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "claude",
    "codex",
    "openclaw",
    "provider",
    "execution"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@types/node": "^25.3.5",
    "opencode-ai": "^1.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.24.0",
    "uuid": "^13.0.0"
  }
}
