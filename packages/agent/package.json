{
  "name": "@agentex/agent",
  "version": "0.0.31",
  "description": "Programmatic execution of AI coding agents including Claude Code, Codex, Cursor, and OpenCode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dynamismlabs/agentex.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/dynamismlabs/agentex/tree/main/packages/agent#readme",
  "bugs": {
    "url": "https://github.com/dynamismlabs/agentex/issues"
  },
  "type": "module",
  "exports": {
    ".":          { "types": "./dist/index.d.ts",        "import": "./dist/index.js",        "default": "./dist/index.js" },
    "./registry": { "types": "./dist/registry.d.ts",     "import": "./dist/registry.js",     "default": "./dist/registry.js" },
    "./derived":  { "types": "./dist/derived.d.ts",      "import": "./dist/derived.js",      "default": "./dist/derived.js" },
    "./types":    { "types": "./dist/types.d.ts",        "import": "./dist/types.js",        "default": "./dist/types.js" },
    "./goals":    { "types": "./dist/goals/index.d.ts",  "import": "./dist/goals/index.js",  "default": "./dist/goals/index.js" },
    "./history":  { "types": "./dist/history/index.d.ts", "import": "./dist/history/index.js", "default": "./dist/history/index.js" },
    "./sessions": { "types": "./dist/sessions/index.d.ts", "import": "./dist/sessions/index.js", "default": "./dist/sessions/index.js" },
    "./utils/*":  { "types": "./dist/utils/*.d.ts",      "import": "./dist/utils/*.js",      "default": "./dist/utils/*.js" },
    "./providers/*": { "types": "./dist/providers/*/index.d.ts", "import": "./dist/providers/*/index.js", "default": "./dist/providers/*/index.js" },
    "./providers/claude/parse":      { "types": "./dist/providers/claude/parse.d.ts",      "import": "./dist/providers/claude/parse.js",      "default": "./dist/providers/claude/parse.js" },
    "./providers/claude/transcript": { "types": "./dist/providers/claude/transcript.d.ts", "import": "./dist/providers/claude/transcript.js", "default": "./dist/providers/claude/transcript.js" },
    "./providers/codex/transcript":  { "types": "./dist/providers/codex/transcript.d.ts",  "import": "./dist/providers/codex/transcript.js",  "default": "./dist/providers/codex/transcript.js" },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:mock": "tsx scripts/smoke.ts --mock",
    "smoke:concurrent": "tsx scripts/concurrent-smoke.ts",
    "demo:durable": "tsx scripts/durable-session-demo.ts",
    "diagnose:history": "tsx scripts/local-history-diagnostic.ts",
    "list-models": "tsx scripts/list-models.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "claude",
    "codex",
    "cursor",
    "opencode",
    "openclaw",
    "provider",
    "execution"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.62.0",
    "@types/node": "^25.3.5",
    "esbuild": "^0.27.0",
    "opencode-ai": "^1.3.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.24.0"
  }
}
