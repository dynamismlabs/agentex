{
  "name": "@agentex/workspace",
  "version": "0.0.1",
  "description": "Isolation and lifecycle primitives for agent workspaces (bare directories and git worktrees)",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "agent",
    "workspace",
    "worktree",
    "git",
    "isolation"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "os": ["darwin", "linux"],
  "dependencies": {
    "chokidar": "^3.6.0",
    "picomatch": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "@types/picomatch": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
