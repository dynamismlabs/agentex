{
  "name": "@agentex/github",
  "version": "0.0.2",
  "description": "Thin typed wrapper over the gh CLI for PR / issue / status operations",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dynamismlabs/agentex.git",
    "directory": "packages/github"
  },
  "homepage": "https://github.com/dynamismlabs/agentex/tree/main/packages/github#readme",
  "bugs": {
    "url": "https://github.com/dynamismlabs/agentex/issues"
  },
  "type": "module",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js", "default": "./dist/index.js" },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "prepack": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "smoke": "tsx scripts/smoke.ts"
  },
  "keywords": [
    "ai",
    "agent",
    "github",
    "gh",
    "pull-request",
    "issue"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.32.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "os": ["darwin", "linux"],
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
